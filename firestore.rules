rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Master Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    // Only includes verified email for admin check
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "osmosistrade5@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // 3. Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.role in ['ADMIN', 'BRAND', 'INFLUENCER'] &&
             data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    // 4. Match Blocks
    match /users/{userId} {
      // PII Protection: Only owner or admin can read
      allow read: if isOwner(userId) || isAdmin();
      
      // Connection test document
      match /test/connection {
        allow read: if true; 
      }
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role) || isAdmin();
    }

    match /brands/{brandId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow update: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    match /influencers/{influencerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow update: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Simplified for initial setup, usually check role
      allow update: if isSignedIn(); // Simplified
      
      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /links/{shortCode} {
      allow read: if true; // Public access for redirects
      allow write: if isSignedIn();
    }

    match /clicks/{clickId} {
      allow read: if isAdmin();
      allow create: if true; // Public tracking
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
